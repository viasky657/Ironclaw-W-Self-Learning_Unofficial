{
  "type": "object",
  "required": ["action"],
  "oneOf": [
    {
      "properties": {
        "action": { "const": "scan" },
        "addresses": {
          "type": "array",
          "items": { "type": "string", "description": "EVM (0x...) or NEAR account ID" },
          "minItems": 1,
          "description": "Wallet addresses to scan"
        },
        "chains": {
          "oneOf": [
            { "type": "string", "const": "*" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "default": "*",
          "description": "Wildcard '*' or explicit chain ID list"
        },
        "at": {
          "type": "object",
          "properties": {
            "block": {
              "type": "object",
              "additionalProperties": { "type": "integer", "minimum": 0 },
              "description": "Per-chain block heights for historical queries"
            },
            "timestamp": {
              "type": "integer",
              "description": "Unix timestamp (seconds) for historical queries"
            }
          }
        },
        "source": {
          "type": "string",
          "enum": ["auto", "fixture", "dune", "dune-replay", "near", "near-replay"],
          "default": "auto",
          "description": "Indexer backend. 'auto' detects per address (EVM→dune, NEAR→near). 'fixture' for embedded test data, 'dune'/'near' for live APIs, '*-replay' for recorded fixtures."
        }
      },
      "required": ["action", "addresses"]
    },
    {
      "properties": {
        "action": { "const": "propose" },
        "positions": {
          "type": "array",
          "description": "Output of a previous scan call (ClassifiedPosition[])"
        },
        "strategies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Markdown strategy docs (with YAML frontmatter). Optional — defaults to bundled strategies (stablecoin-yield-floor, lending-health-guard, lp-impermanent-loss-watch, near-staking-yield, near-lending-yield, near-lp-yield) when omitted."
        },
        "config": {
          "type": "object",
          "description": "Project configuration. Optional — defaults to {floor_apy: 0.04, max_risk_score: 3, notify_threshold_usd: 100, auto_intent_ceiling_usd: 1000, max_slippage_bps: 50}."
        }
      },
      "required": ["action", "positions"]
    },
    {
      "properties": {
        "action": { "const": "build_intent" },
        "plan": {
          "type": "object",
          "description": "MovementPlan from a Proposal. See Proposal.movement_plan."
        },
        "config": {
          "type": "object",
          "description": "Project configuration. Optional — defaults to standard config."
        },
        "solver": {
          "type": "string",
          "enum": ["fixture", "near-intents", "replay"],
          "default": "fixture",
          "description": "Solver backend. M1: 'fixture'. M4: 'near-intents' live, 'replay' for recorded quotes."
        }
      },
      "required": ["action", "plan"]
    },
    {
      "properties": {
        "action": { "const": "format_suggestion" },
        "positions": {
          "type": "array",
          "description": "ClassifiedPosition[] from a previous scan"
        },
        "proposals": {
          "type": "array",
          "description": "Proposal[] from a previous propose call"
        },
        "config": {
          "type": "object",
          "description": "Project configuration"
        },
        "generated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp. Optional — the markdown omits the line if absent."
        },
        "previous_total_value_usd": {
          "type": "string",
          "description": "Net value from the previous run's state/latest.json. Optional; enables the Δ vs last run line."
        }
      },
      "required": ["action", "positions", "proposals", "config"]
    },
    {
      "properties": {
        "action": { "const": "progress" },
        "history": {
          "type": "array",
          "description": "Dated historical state snapshots (from state/history/*.json)",
          "items": {
            "type": "object",
            "properties": {
              "date": { "type": "string" },
              "positions": { "type": "array" }
            },
            "required": ["date", "positions"]
          }
        },
        "config": {
          "type": "object",
          "description": "Project configuration"
        }
      },
      "required": ["action", "history", "config"]
    },
    {
      "properties": {
        "action": { "const": "format_widget" },
        "positions": { "type": "array", "description": "ClassifiedPosition[] from scan" },
        "proposals": { "type": "array", "description": "Proposal[] from propose" },
        "config": { "type": "object" },
        "pending_intents": {
          "type": "array",
          "description": "Outstanding intent bundles with their status (awaiting-signature / submitted / failed)"
        },
        "generated_at": { "type": "string" },
        "next_mission_run": { "type": "string" },
        "project_id": { "type": "string" },
        "previous_total_value_usd": { "type": "string" },
        "progress": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "value": { "type": "number" }
          }
        }
      },
      "required": ["action", "positions", "proposals", "config"]
    }
  ]
}
